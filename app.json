{
  "expo": {
    "name": "Mobile Game",
    "slug": "mobile-game-framework",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mobile-game",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobilegame.framework"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.mobilegame.framework"
    },
    "plugins": ["expo-router"]
  }
}
